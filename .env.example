# Backend Setup
POSTGRES_USER=chatsmart
POSTGRES_PASSWORD=chatsmart
POSTGRES_DB=chatsmart_db
DATABASE_URL=postgresql+asyncpg://chatsmart:chatsmart@localhost:5432/chatsmart_db

# Redis setup
REDIS_URL=redis://localhost:6379/0

# Security
JWT_SECRET=supersecret_jwt_key_that_must_be_changed_in_prod
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
IS_PRODUCTION=false # Set to true on your live Contabo VPS to enforce Secure cookie flag

# Backend FastAPI Host
API_HOST=0.0.0.0
API_PORT=8000

# AI Configuration
OPENAI_API_KEY=
GEMINI_API_KEY=

# CORS — comma-separated or JSON array of allowed frontend origins
# This MUST include your frontend URL or login will fail (CORS blocks the response)
BACKEND_CORS_ORIGINS=http://localhost:3000

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
